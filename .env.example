# ============================================================
# DeepSeek Cursor Proxy — Docker environment variables
# Usage: cp .env.example .env → edit → docker compose up -d
# See DOCKER.md for full instructions.
# ============================================================

# --- Network -------------------------------------------------
PROXY_HOST=0.0.0.0
PROXY_PORT=9000

# --- Upstream API --------------------------------------------
PROXY_BASE_URL=https://api.deepseek.com
PROXY_MODEL=deepseek-v4-pro
PROXY_THINKING=enabled                # enabled | disabled
PROXY_REASONING_EFFORT=max            # low | medium | high | max | xhigh
PROXY_REQUEST_TIMEOUT=300
PROXY_MAX_REQUEST_BODY_BYTES=20971520 # 20 MB
PROXY_MISSING_REASONING_STRATEGY=recover  # recover | reject
PROXY_USER_MESSAGE_SUFFIX=

# --- Ngrok tunnel --------------------------------------------
PROXY_NGROK=0                         # 1 = enabled, 0 = disabled
# PROXY_NGROK_URL=                    # custom ngrok URL / reserved domain

# --- Reasoning cache -----------------------------------------
PROXY_REASONING_CONTENT_PATH=/data/reasoning_content.sqlite3
PROXY_REASONING_CACHE_MAX_AGE_SECONDS=2592000  # 30 days
PROXY_REASONING_CACHE_MAX_ROWS=100000

# --- Display -------------------------------------------------
PROXY_DISPLAY_REASONING=1             # 1 = on, 0 = off
PROXY_COLLAPSIBLE_REASONING=1         # 1 = on, 0 = off

# --- Misc ----------------------------------------------------
PROXY_CORS=0                          # 1 = on, 0 = off
PROXY_VERBOSE=0                       # 1 = on, 0 = off
# PROXY_TRACE_DIR=/data/traces
# PROXY_CONFIG=/data/config.yaml
